RewriteEngine On

# 1. ป้องกันการเข้าถึงไฟล์ที่สำคัญ
<Files "config/db.php">
    Order allow,deny
    Deny from all
</Files>

# 2. Friendly URL สำหรับหน้าสินค้า
RewriteRule ^product/([a-zA-Z0-9-]+)$ modules/product-detail.php?slug=$1 [L,QSA]

# 3. Friendly URL สำหรับหน้าประวัติ (รายเดือน/ปี)
RewriteRule ^history/([0-9]{4})/([0-9]{2})$ modules/history.php?year=$1&month=$2 [L,QSA]